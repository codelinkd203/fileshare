{
  "name": "fileshare",
  "version": "1.0.0",
  "description": "FileShare — instant wireless file transfer across any device, anywhere",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "archiver": "^6.0.2",
    "express": "^4.22.1",
    "fs-extra": "^11.3.4",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "open": "^8.4.2",
    "os": "^0.1.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.fileshare.app",
    "productName": "FileShare",
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
